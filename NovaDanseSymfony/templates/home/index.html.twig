<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Helvetica', sans-serif;

}

body {
    background: linear-gradient(90deg, #0088FF, #CE61C2); /* Dégradé linéaire horizontal */
    height: 100vh; /* Assure que le dégradé couvre toute la hauteur de la fenêtre */
    margin: 0;
    color: white;
}

nav {
    color: black;
   

}

.NavBar {
    background-color: #E1BAD9;
    height: 120px;
    display: flex;
    align-items: center;
