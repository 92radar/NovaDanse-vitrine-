}
.Section h1{
    margin-left: 20px;
    font-size: 38px;
    font-weight: normal;
    padding:10px;
}
.button {
    display: inline-block;
    position: relative; /* nécessaire pour ::after */
    background-color: rgb(255, 255, 255);
    color: black;
    padding: 10px 20px;
    border: 1px solid white;
    cursor: pointer;
    margin: 20px;
    transition: background-color 0.3s, transform 0.2s;
    right: 20px;

/* optionnel, pour arrondir le bouton et le calque */
}
.button p{
    font-size: 20px;
    margin:20px;
}


.button::after {
    content: '';
    position: absolute;
    top: 10px;       /* décalage vertical du calque */
    left: 10px;      /* décalage horizontal du calque */
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, #CE61C2, #0088FF);
 /* doit correspondre au bouton */
    z-index: -1;         /* derrière le bouton */
    pointer-events: none; /* ne bloque pas le clic */
    transition: all 0.2s;
}
.flyer p{
    text-align: center;
    font-size: 28px;
    margin-bottom: 40px;
    font-weight: lighter;
    
}

.flyer h1{
    text-align: center;
