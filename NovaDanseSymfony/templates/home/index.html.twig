<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Helvetica', sans-serif;

}

body {
    background: linear-gradient(90deg, #0088FF, #CE61C2); /* Dégradé linéaire horizontal */
    height: 100vh; /* Assure que le dégradé couvre toute la hauteur de la fenêtre */
    margin: 0;
    color: white;
}

nav {
    color: black;
   

}

.NavBar {
    background-color: #E1BAD9;
    height: 120px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 20px;
    position: sticky;
    top: 0;
}

.NavBar ul {
    list-style: none;
    display: flex;
    align-items: center;
    margin: 0;
    padding: 0;
}
.NavBar ul li a:hover{
   color:rgb(255, 255, 255);
    transition: 0.3s;
}

.NavBar ul li:first-child {
    display: inline-block;
    padding: 20px;
    font-size: 24px; /* Taille de police plus grande pour le premier élément */
    font-weight: normal;
}
.NavBar ul li:not(:first-child) {
    display: inline-block;
    padding: 20px;
    font-size: 16px; /* Taille de police plus petite pour les autres éléments */
    font-weight: lighter;
    float: right;
}

.NavBar ul li a {
    text-decoration: none;
    color: black;
}
img{
    max-width: 100%;
