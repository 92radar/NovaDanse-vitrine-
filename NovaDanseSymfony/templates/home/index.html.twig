}
@keyframes dissolveIn {
    from {
        opacity: 0;
    }
    to {
        opacity: 1;
    }
}
.menu-icon {
    display: none; /* Caché par défaut */
    flex-direction: column;
    cursor: pointer;
}
.menu-icon .bar {
    width: 30px;
    height: 4px;
