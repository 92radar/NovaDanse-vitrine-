    padding: 20px;
    text-align: center;
    width: auto;
    min-width: 100px;
    height: auto;
    margin: 20px;
    display: inline-block;
    color: black;

}
.dates h2{
    font-size: 38px;
    margin-bottom: 10px;
    color: black;
}


.container {
    display: flex; /* Active Flexbox pour aligner les éléments côte à côte */
    justify-content:start;  /* Ajoute de l'espace entre les éléments */
    align-items: center; /* Aligne les éléments verticalement */
    gap: 0; /* Ajoute un espacement entre les éléments */
    margin: 10px;
}
.Information{
    background: transparent;
    border-radius: 10px;
    padding: 20px;
    width: 600px;
    height: auto;
    min-height: auto;
    border: 1px solid white;

}
.Information p{
    font-size: 10px;

}
.Information:hover{
    background: rgba(255, 255, 255, 0.44);
    transition: 0.3s;
}

.geometry{
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr 1fr;
  width: 500px;
  height: 500px;
  margin: 40px auto;
  margin-top:150px;
  gap: 0;
  overflow: visible;
  max-width: 100%;
  
}

.cell{
  position: relative;
  overflow: visible;
  max-width: 100%;
  
}

.shape{
  position: absolute;
  background-color: #E1BAD9;
  border: 1px solid transparent;
  box-sizing: border-box;
  transition: transform 0.2s ease, opacity 0.2s ease;
 
 
}

/* Shape 1 — reste au centre en haut à gauche */
.cell-tl .shape1{
  width: 90%;
  height: 90%;
  background-color: #483097;
  border-radius: 194px 194px 0 194px;

  bottom: 0;
  right: 0;
  transform: translate(0, 0);
}

/* Shape 2 — descend légèrement pour casser la symétrie */
.cell-tr .shape2{
  width: 150%;
  height: 150%;
  border-radius: 372px 372px 372px 0;
  background-color: #312493;

  bottom: 0;
  left: 0;
  transform: translate(0, 30px); /* ↓ descend de 30px */
}

/* Shape 3 — remonte légèrement pour créer la croix */
.cell-bl .shape3{
  width: 130%;
  height: 130%;
  border-radius: 372px 0 372px 372px;

  background-color: #312493;
  top: 0;
  right: 0;
  transform: translate(0, -30px); /* ↑ monte de 30px */
}

/* Shape 4 — reste neutre ou légèrement décalée si besoin */
.cell-br .shape4{
  width: 100%;
  height: 100%;
  background-color: #483097;
  border-radius: 0 194px 194px 194px;

  top: 0;
  left: 0;
  transform: translate(0, 0);
}

.geometry p{
    position: absolute;
    color: white;
    font-size: 24px;
    font-weight: bold;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 1;
}
.SectionsContainer {
  display: grid;
  margin:20px;
  grid-template-columns: 1fr auto; /* texte à gauche, bouton à droite */
  gap: 20px; /* espace entre texte et bouton */
  margin-bottom: 40px;
  max-width: 100%;
}
.Section {
  display: contents; /* permet au grid de gérer directement texte et bouton */
}
.Section .button {
  align-self: start; /* aligne le bouton en haut du texte */
}
.Section p{
    margin: 20px;
    font-size: 22px;
    font-weight: lighter;
    line-height: 1.6;
}
.Section h1{
    margin-left: 20px;
    font-size: 38px;
    font-weight: normal;
    padding:10px;
}
.button {
    display: inline-block;
    position: relative; /* nécessaire pour ::after */
    background-color: rgb(255, 255, 255);
    color: black;
    padding: 10px 20px;
    border: 1px solid white;
    cursor: pointer;
    margin: 20px;
    transition: background-color 0.3s, transform 0.2s;
    right: 20px;

/* optionnel, pour arrondir le bouton et le calque */
}
.button p{
    font-size: 20px;
    margin:20px;
}

.button::after {
    content: '';
    position: absolute;
    top: 10px;       /* décalage vertical du calque */
    left: 10px;      /* décalage horizontal du calque */
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, #CE61C2, #0088FF);
 /* doit correspondre au bouton */
    z-index: -1;         /* derrière le bouton */
    pointer-events: none; /* ne bloque pas le clic */
    transition: all 0.2s;
}
.flyer p{
    text-align: center;
    font-size: 28px;
    margin-bottom: 40px;
    font-weight: lighter;
    
}

.flyer h1{
    text-align: center;
    font-size: 180px;
    font-weight: bold;
    padding:0px;
    padding-top:0px;
    color: blue;

}
.flyer {
  position: relative;
  max-width: 100%;

  padding: 20px;
  color: white;
  overflow: hidden; /* pour éviter que l'image déborde */
}

.flyer-bg {
  position: absolute;
  top: 0;
  left: 100px;
  width: 90%;
  height: 90%;
  object-fit: contain; /* l'image couvre tout le bloc */
  z-index: -1; /* passe l'image derrière le contenu */
  opacity: 0.8; /* facultatif, pour laisser le texte bien lisible */
   transition: transform 1.2s ease-out, opacity 1s ease-out;
}
.anim-img, .anim-top, .anim-left {
  opacity: 0;
  transition: transform 0.4s ease-out, opacity 0.4s ease-out;
}
.FAQ{
    margin: 20px;
    padding: 20px;
    max-width: 100%;
}
.separator {
    height: 1px;
    background-color: white;
    margin: 10px 0;
    width: 100%;
    margin-top: 10px;
}
.fa-solid {
    float: right;
