{% extends 'base.html.twig' %}

{% block title %}Hello Nova Danse{% endblock %}

{% block body %}
<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;




}

body {
    background: linear-gradient(90deg, #0088FF,rgb(234, 117, 220));
background: radial-gradient(circle at center, #0088FF 0%,rgb(4, 19, 117)  30%,#E1BAD9 90%); /* Dégradé linéaire horizontal */
    height: 100vh; /* Assure que le dégradé couvre toute la hauteur de la fenêtre */
    margin: 0;
    color: white;
    max-width: 100%;
    overflow-x: hidden;
}

nav {
    color: black;
    max-width: 100%;
   

}

.NavBar {
    background-color: #E1BAD9;
    height: 120px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 20px;
    position: sticky;
    top: 0;
}

.NavBar ul {
    list-style: none;
    display: flex;
    align-items: center;
    margin: 0;
    padding: 0;
}
.NavBar ul li a:hover{
   color:rgb(255, 255, 255);
    transition: 0.3s;
}

.NavBar ul li:first-child {
    display: inline-block;
    padding: 20px;
    font-size: 24px; /* Taille de police plus grande pour le premier élément */
    font-weight: normal;
}
.NavBar ul li:not(:first-child) {
    display: inline-block;
    padding: 20px;
    font-size: 16px; /* Taille de police plus petite pour les autres éléments */
    font-weight: lighter;
    float: right;
}

.NavBar ul li a {
    text-decoration: none;
    color: black;
}
img{
    max-width: 100%;
    height: auto;
    border-radius: 10px;

}
.header{

    text-align: center;
    margin-top: 20px;
    margin: 20px 20px;
    animation: dissolveIn 2s ease-in-out;
}


@keyframes dissolveIn {
    from {
        opacity: 0;
    }
    to {
        opacity: 1;
    }
}
.menu-icon {
    display: none; /* Caché par défaut */
    flex-direction: column;
    cursor: pointer;
}
.menu-icon .bar{
    width: 30px;
    height: 4px;
    background-color: white;
    margin: 4px 0;
    border-radius: 20px;
}
.menu-icon .bar:nth-child(2) {
  width: 20px; /* plus court que les autres */
   /* ou à gauche/droite selon le style désiré */
}


h1{
   font-family: "Lilita One", sans-serif;
    margin-left: 20px;
    color: #A1E1BC;
    font-size: 64px;
    font-weight: normal;
    padding:30px;
}

.container {
    display: flex;
    border-radius: 20px;
    margin-bottom: 20px;
    max-width: 100%;
    margin-left: 40px;               /* marge à gauche */
            /* arrondis propres */
    box-shadow: 0 4px 10px rgba(0,0,0,0.1); /* petite ombre douce */
}

 .information {
    padding: 15px 20px;
    border-radius: 20px;
    font-style: lighter;
}

.dates {
    text-align: center;
    background: linear-gradient(90deg, rgb(228, 196, 109),rgb(202, 120, 192));
