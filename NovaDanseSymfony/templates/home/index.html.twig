    flex-direction: column;
    justify-content: center;
    padding: 15px 20px;
    border-radius: 20px;
}
.lieu{
  color:rgb(231, 188, 69);
  
}
.container:hover{
    box-shadow: 0 8px 20px rgba(0,0,0,0.2); /* ombre plus prononcée au survol */
    transform: translateX(-10px); /* léger déplacement vers le haut */
    transition: transform 0.3s, box-shadow 0.3s; /* transition douce */
}

.geometry{
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr 1fr;
  width: 500px;
  height: 500px;
  margin: 40px auto;
  margin-top:150px;
  gap: 0;
  overflow: visible;
  max-width: 100%;
  
}

.cell{
  position: relative;
  overflow: visible;
  max-width: 100%;
  
}

.shape{
  position: absolute;
  background-color: #E1BAD9;

  
  
  box-sizing: border-box;
  transition: transform 0.2s ease, opacity 0.2s ease;
 
 
}

/* Shape 1 — reste au centre en haut à gauche */
.cell-tl .shape1{
  width: 90%;
  height: 90%;
  background-color: #483097;
  border-radius: 194px 194px 0 194px;
  box-shadow: 0 16px 28px rgba(0,0,0,0.1);

  bottom: 0;
  right: 0;
  transform: translate(0, 0);
}

/* Shape 2 — descend légèrement pour casser la symétrie */
.cell-tr .shape2{
  width: 150%;
  height: 150%;
  border-radius: 372px 372px 372px 0;
  background-color: #312493;
  box-shadow: 0 16px 28px rgba(0,0,0,0.1);

  bottom: 0;
  left: 0;
  transform: translate(0, 30px); /* ↓ descend de 30px */
}

/* Shape 3 — remonte légèrement pour créer la croix */
.cell-bl .shape3{
  width: 130%;
  height: 130%;
  border-radius: 372px 0 372px 372px;
  box-shadow: 0 16px 28px rgba(0,0,0,0.1);

  background-color: #312493;
  top: 0;
  right: 0;
  transform: translate(0, -30px); /* ↑ monte de 30px */
}

/* Shape 4 — reste neutre ou légèrement décalée si besoin */
.cell-br .shape4{
  width: 100%;
  height: 100%;
  background-color: #483097;
  border-radius: 0 194px 194px 194px;
  box-shadow: 0 16px 28px rgba(0,0,0,0.1);

  top: 0;
  left: 0;
  transform: translate(0, 0);
}

.geometry p{
    position: absolute;
    color: white;
    font-size: 24px;
    font-weight: bold;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 1;
}
.SectionsContainer {
  display: grid;
  margin:20px;
  grid-template-columns: 1fr auto; /* texte à gauche, bouton à droite */
  gap: 20px; /* espace entre texte et bouton */
