.Information:hover{
    background: rgba(255, 255, 255, 0.44);
    transition: 0.3s;
}

.geometry{
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr 1fr;
  width: 500px;
  height: 500px;
  margin: 40px auto;
  margin-top:150px;
  gap: 0;
  overflow: visible;
  max-width: 100%;
  
}

.cell{
  position: relative;
  overflow: visible;
  max-width: 100%;
  
}

.shape{
  position: absolute;
  background-color: #E1BAD9;
  border: 1px solid transparent;
  box-sizing: border-box;
  transition: transform 0.2s ease, opacity 0.2s ease;
 
 
}

/* Shape 1 — reste au centre en haut à gauche */
.cell-tl .shape1{
  width: 90%;
  height: 90%;
  background-color: #483097;
  border-radius: 194px 194px 0 194px;

  bottom: 0;
  right: 0;
  transform: translate(0, 0);
}

/* Shape 2 — descend légèrement pour casser la symétrie */
.cell-tr .shape2{
  width: 150%;
  height: 150%;
  border-radius: 372px 372px 372px 0;
  background-color: #312493;

  bottom: 0;
  left: 0;
  transform: translate(0, 30px); /* ↓ descend de 30px */
}

/* Shape 3 — remonte légèrement pour créer la croix */
.cell-bl .shape3{
  width: 130%;
  height: 130%;
  border-radius: 372px 0 372px 372px;

  background-color: #312493;
  top: 0;
  right: 0;
  transform: translate(0, -30px); /* ↑ monte de 30px */
}

/* Shape 4 — reste neutre ou légèrement décalée si besoin */
.cell-br .shape4{
  width: 100%;
  height: 100%;
  background-color: #483097;
  border-radius: 0 194px 194px 194px;

  top: 0;
  left: 0;
  transform: translate(0, 0);
}

.geometry p{
    position: absolute;
    color: white;
    font-size: 24px;
    font-weight: bold;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 1;
}
.SectionsContainer {
  display: grid;
  margin:20px;
  grid-template-columns: 1fr auto; /* texte à gauche, bouton à droite */
  gap: 20px; /* espace entre texte et bouton */
