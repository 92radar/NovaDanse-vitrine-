}

        
@media (max-width: 900px) {
    .NavBar ul li:not(:first-child) {
        display:none;
    }
   .menu-icon {
        display: flex; /* Affiche le menu burger */
    }
    .shape{
        max-width: 100%;
min-height: auto; 
