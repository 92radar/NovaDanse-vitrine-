{% extends 'base.html.twig' %}

{% block title %} NØVA DANSE Back Office{% endblock %}

{% block body %}
<style>
/* ... (Votre CSS existant pour h1, :root, html/body, nav-bar, etc.) ... */

h1 {
    text-align: center;
    margin-top: 50px;
    font-family: 'Arial', sans-serif;
    color: white;
}
/* Définition des Variables */
:root {
    --background:linear-gradient(90deg, #0088FF, #CE61C2); 
    --navbar-width: 256px;
    --navbar-width-min: 80px;
    --navbar-dark-primary: #18283b;
    --navbar-dark-secondary: #2c3e50;
    --navbar-light-primary: #f5f6fa;
    --navbar-light-secondary: #8392a5;
    /* Couleur utilisée dans les cartes de stats */
    --card-background: rgba(255, 255, 255, 0.1); 
    --card-shadow: 0 4px 6px rgba(0, 0, 0, 0.2);
}

/* Styles pour HTML et Body */
html, body {
    margin: 0;
    background: var(--background);
}

/* ---------------------------------------------------------------------- */
/* AJOUTS POUR LE CONTENU PRINCIPAL */
/* ---------------------------------------------------------------------- */
#main-container {
    margin-left: calc(var(--navbar-width) + 3vw);
    width: calc(100% - var(--navbar-width) - 4vw);
    min-height: 100vh;
    padding-top: 10px;
}

/* Styles pour la réduction de la barre de navigation */
#nav-toggle:checked ~ #main-container {
    margin-left: calc(var(--navbar-width-min) + 3vw);
    width: calc(100% - var(--navbar-width-min) - 4vw);
}

/* Styles pour les sections */
#main-content, #update-section, #stats-section {
    padding: 20px;
}

/* ---------------------------------------------------------------------- */
/* STYLES DES CARTES DE STATISTIQUES */
/* ---------------------------------------------------------------------- */

#stats-container {
    display: flex;
    justify-content: space-around;
    flex-wrap: wrap;
    gap: 20px;
    margin-top: 40px;
}

.stat-card {
    background: var(--card-background);
    border-radius: 12px;
    padding: 25px 30px;
    width: 280px;
    box-shadow: var(--card-shadow);
    text-align: center;
    backdrop-filter: blur(5px);
    transition: transform 0.3s, box-shadow 0.3s;
    color: white; /* Texte blanc pour contraster avec le background */
    border: 1px solid rgba(255, 255, 255, 0.2);
}

.stat-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 15px rgba(0, 0, 0, 0.3);
}

.stat-value {
    font-size: 3rem;
    font-weight: bold;
    margin: 10px 0 5px 0;
    color: var(--navbar-light-primary);
}

.stat-label {
    font-size: 1rem;
    color: var(--navbar-light-secondary);
}

.stat-period {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.6);
    margin-top: 20px;
}


/* ... (Le reste de votre CSS existant) ... */
/* Styles pour LOGIQUE DE REDUCTION, STYLES DE LA BARRE DE NAVIGATION, etc. */
/* (Je ne les répète pas ici pour ne pas alourdir le fichier) */

/* Sélecteurs généraux de réduction (header, content, footer) */
#nav-toggle:checked ~ #nav-header {
    width: calc(var(--navbar-width-min) - 16px);
}

#nav-toggle:checked ~ #nav-content,
#nav-toggle:checked ~ #nav-footer {
    width: var(--navbar-width-min);
}

/* Réduction du titre */
#nav-toggle:checked ~ #nav-header #nav-title {
    opacity: 0;
    pointer-events: none;
    transition: opacity .1s;
}

/* Positionnement du bouton hamburger */
#nav-toggle:checked ~ #nav-header label[for="nav-toggle"] {
    left: calc(50% - 8px);
    transform: translate(-50%);
}

/* Style du bouton hamburger */
#nav-toggle:checked ~ #nav-header #nav-toggle-burger {
    background: var(--navbar-light-primary);
}

#nav-toggle:checked ~ #nav-header #nav-toggle-burger:before,
#nav-toggle:checked ~ #nav-header #nav-toggle-burger::after {
    width: 16px;
    background: var(--navbar-light-secondary);
    transform: translate(0, 0) rotate(0deg);
}

/* Réduction du contenu */
#nav-toggle:checked ~ #nav-content .nav-button span {
    opacity: 0;
    transition: opacity .1s;
}

#nav-toggle:checked ~ #nav-content .nav-button .fas {
    min-width: calc(100% - 16px);
}

/* Réduction du pied de page */
#nav-toggle:checked ~ #nav-footer #nav-footer-avatar {
    margin-left: 0;
    left: 50%;
    transform: translate(-50%);
}

#nav-toggle:checked ~ #nav-footer #nav-footer-titlebox,
#nav-toggle:checked ~ #nav-footer label[for="nav-footer-toggle"] {
    opacity: 0;
    transition: opacity .1s;
    pointer-events: none;
}

/* ---------------------------------------------------------------------- */
/* STYLES DE LA BARRE DE NAVIGATION (#nav-bar) */
/* ---------------------------------------------------------------------- */

#nav-bar {
    position: fixed; /* Rendu 'fixed' pour que le contenu principal puisse défiler */
    left: 1vw;
    top: 1vw;
    height: calc(100% - 2vw);
    background: var(--navbar-dark-primary);
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    color: var(--navbar-light-primary);
    font-family: Verdana, Geneva, Tahoma, sans-serif;
    overflow: hidden;
    user-select: none;
    z-index: 1000;
}

#nav-bar hr {
    margin: 0;
    position: relative;
    left: 16px;
    width: calc(100% - 32px);
    border: none;
    border-top: solid 1px var(--navbar-dark-secondary);
}

#nav-bar a {
    color: inherit;
    text-decoration: inherit;
}

#nav-bar input[type="checkbox"] {
    display: none;
}

/* ---------------------------------------------------------------------- */
/* STYLES DU HEADER (#nav-header) */
/* ---------------------------------------------------------------------- */

#nav-header {
    position: relative;
    width: var(--navbar-width);
    left: 16px;
    width: calc(var(--navbar-width) - 16px);
    min-height: 80px;
    background: var(--navbar-dark-primary);
    border-radius: 16px;
    z-index: 2;
    display: flex;
    align-items: center;
    transition: width .2s;
}

#nav-header hr {
    position: absolute;
    bottom: 0;
}

#nav-title {
    font-size: 1.5rem;
    transition: opacity 1s;
}

/* ---------------------------------------------------------------------- */
/* STYLES DU TOGGLE BURGER */
/* ---------------------------------------------------------------------- */

label[for="nav-toggle"] {
    position: absolute;
    right: 0;
    width: 3rem;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
}

#nav-toggle-burger {
    position: relative;
    width: 16px;
    height: 2px;
    background: var(--navbar-dark-primary);
    border-radius: 99px;
    transition: background .2s;
}

#nav-toggle-burger:before,
#nav-toggle-burger:after {
    content: '';
    position: absolute;
    top: -6px;
    width: 10px;
    height: 2px;
    background: var(--navbar-light-primary);
    border-radius: 99px;
    transform: translate(2px, 8px) rotate(30deg);
    transition: .2s;
}

#nav-toggle-burger:after {
    top: 6px;
    transform: translate(2px, -8px) rotate(-30deg);
}

/* ---------------------------------------------------------------------- */
/* STYLES DU CONTENU DE NAVIGATION (#nav-content) */
/* ---------------------------------------------------------------------- */

#nav-content {
    margin: -16px 0;
    padding: 16px 0;
    position: relative;
    flex: 1;
    width: var(--navbar-width);
    background: var(--navbar-dark-primary);
    box-shadow: 0 0 0 16px var(--navbar-dark-primary);
    direction: rtl; /* Pour forcer la scrollbar à droite */
    overflow-x: hidden;
    transition: width .2s;
}

#nav-content::-webkit-scrollbar {
    width: 8px;
    height: 8px;
}

#nav-content::-webkit-scrollbar-thumb {
    border-radius: 99px;
    background-color: #D62929;
}

#nav-content::-webkit-scrollbar-button {
    height: 16px;
}

/* ---------------------------------------------------------------------- */
/* STYLES DES BOUTONS DE NAVIGATION (.nav-button) */
/* ---------------------------------------------------------------------- */

.nav-button {
    position: relative;
    margin-left: 16px;
    height: 54px;
    display: flex;
    align-items: center;
    color: var(--navbar-light-secondary);
    direction: ltr; /* Rétablit la direction du texte pour les boutons */
    cursor: pointer;
    z-index: 1;
    transition: color .2s;
}

.nav-button span {
    transition: opacity 1s;
}

.nav-button .fas {
    min-width: 3rem;
    text-align: center;
}

/* Remplacement de la boucle @for pour le survol et le highlight */
/* Les sélecteurs ci-dessous gèrent la couleur au survol */
.nav-button:hover { color: var(--navbar-dark-primary); }
/* Les sélecteurs ci-dessous gèrent le positionnement du highlight au survol */
.nav-button:nth-of-type(1):hover ~ #nav-content-highlight { top: 16px; } /* (1-1)*54 + 16 */
.nav-button:nth-of-type(2):hover ~ #nav-content-highlight { top: 70px; } /* (2-1)*54 + 16 */
.nav-button:nth-of-type(3):hover ~ #nav-content-highlight { top: 124px; } /* (3-1)*54 + 16 */
/* ... Continuez pour les autres nav-button si nécessaire (jusqu'à 8) */
.nav-button:nth-of-type(5):hover ~ #nav-content-highlight { top: 232px; } /* Saut de hr */
.nav-button:nth-of-type(6):hover ~ #nav-content-highlight { top: 286px; }
.nav-button:nth-of-type(7):hover ~ #nav-content-highlight { top: 340px; }
.nav-button:nth-of-type(8):hover ~ #nav-content-highlight { top: 394px; }

#nav-bar .fas {
    min-width: 3rem;
    text-align: center;
}

/* ---------------------------------------------------------------------- */
/* STYLES DU HIGHLIGHT (#nav-content-highlight) */
/* ---------------------------------------------------------------------- */

#nav-content-highlight {
    position: absolute;
    left: 16px;
    top: -70px; /* Ajusté de -54-16px */
    width: calc(100% - 16px);
    height: 54px;
    background: var(--background);
    background-attachment: fixed;
    border-radius: 16px 0 0 16px;
    transition: top .2s;
}

#nav-content-highlight:before,
#nav-content-highlight:after {
    content: '';
    position: absolute;
    right: 0;
    bottom: 100%;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    box-shadow: 16px 16px var(--background);
}

#nav-content-highlight:after {
    top: 100%;
    bottom: auto; /* Rétabli pour top */
    box-shadow: 16px -16px var(--background);
}

/* ---------------------------------------------------------------------- */
/* STYLES DU FOOTER (#nav-footer) */
/* ---------------------------------------------------------------------- */

#nav-footer {
    position: relative;
    width: var(--navbar-width);
    height: 54px;
    background: var(--navbar-dark-secondary);
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    z-index: 2;
    transition: width .2s, height .2s;
}

#nav-footer-heading {
    position: relative;
    width: 100%;
    height: 54px;
    display: flex;
    align-items: center;
}

#nav-footer-avatar {
    position: relative;
    margin: 11px 0 11px 16px;
    left: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    overflow: hidden;
    transform: translate(0);
    transition: .2s;
}

#nav-footer-avatar img {
    height: 100%;
}

#nav-footer-titlebox {
    position: relative;
    margin-left: 16px;
    width: 10px;
    display: flex;
    flex-direction: column;
    transition: opacity 1s;
}

#nav-footer-subtitle {
    color: var(--navbar-light-secondary);
    font-size: .6rem;
}

/* Toggle du contenu du footer (ouverture) */
#nav-toggle:not(:checked) ~ #nav-footer-toggle:checked + #nav-footer {
    height: 30%;
    min-height: 54px;
}

#nav-toggle:not(:checked) ~ #nav-footer-toggle:checked + #nav-footer label[for="nav-footer-toggle"] {
    transform: rotate(180deg);
}

label[for="nav-footer-toggle"] {
    position: absolute;
    right: 0;
    width: 3rem;
    height: 100%;
    display: flex;
    align-items: center;
    cursor: pointer;
    transition: transform .2s, opacity .2s;
}

#nav-footer-content {
    margin: 0 16px 16px 16px;
    border-top: solid 1px var(--navbar-light-secondary);
    padding: 16px 0;
    color: var(--navbar-light-secondary);
    font-size: .8rem;
    overflow: auto;
}

#nav-footer-content::-webkit-scrollbar {
    width: 8px;
    height: 8px;
}

#nav-footer-content::-webkit-scrollbar-thumb {
    border-radius: 99px;
    background-color: #D62929;
}

.update-options {
    background-color: transparent;
    padding: 20px;
    border-radius: 10px;
    max-width: 600px;
    margin: 10px auto;
    font-size: 18px;
    color: white;
    font-family: 'Arial', sans-serif;
}

</style>



<nav id="nav-bar">
    <input id="nav-toggle" type="checkbox">
    
    <header id="nav-header">
        <a id="nav-title" href="" target="_blank">
            NØVA DANSE
        </a>
        
        <label for="nav-toggle">
            <span id="nav-toggle-burger"></span>
        </label>
        
        <hr>
    </header>
    
    <div id="nav-content">
        <div class="nav-button">
            <i class="fas fa-home"></i>
            <span>Acceuil</span>
        </div>
        
        <div class="nav-button">
            <i class="fas fa-gear"></i>
            <span>Mettre à jour</span>
        </div>
        
        <div class="nav-button">
            <i class="fas fa-chart-line"></i> <!-- Changement d'icône pour les stats -->
            <span>Statistiques</span>
        </div>
        
        
        
        <div id="nav-content-highlight"></div>
    </div>
    
    <input id="nav-footer-toggle" type="checkbox">
    
    <footer id="nav-footer">
        <div id="nav-footer-heading">
            <div id="nav-footer-avatar">
                <img src="{{ asset('Pictures/pexels-george-desipris-1110704.jpg') }}" alt="Avatar">
            </div>
            
            <div id="nav-footer-titlebox">
                <a id="nav-footer-title" href="" target="_blank">Geoffrey</a>
                <span id="nav-footer-subtitle">Admin</span>
