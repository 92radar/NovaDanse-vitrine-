        <ul>
        <li><a href="{{ path('app_logout') }}">Déconnexion</a></li>
        <li><a href="">Paramètres du compte</a></li>
        <li><a href="">Aide &amp; Support</a></li>
        </ul>
           
        </div>
    </footer>
</nav>

<div id="main-container"> <!-- Conteneur pour décaler le contenu principal -->
    <section id="main-content">
        <!-- Contenu principal du back office -->
        <h1>Tableau de bord</h1>
    </section>
    
    <section id="update-section">
        <h1>Mettre à jour le contenu du site</h1>
        <div class="update-options">
            <p>Choisissez une option pour mettre à jour le contenu du site :</p>
        <ul>
            <li>Mettre à jour la photo bannière</li>
            <li>Mettre à jour les photos des salles</li>
            <li>Mettre à jour les descriptions des cours</li>
        </ul>
        </div>
    </section>

    <section id="stats-section">
        <h1>Statistiques du site</h1>
        
        {# Vérification que les données analytics_stats existent avant l'affichage #}
        {% if analytics_stats is defined and analytics_stats is not empty %}
            <div class="stat-period">
                Données Google Analytics 4 (GA4) pour les {{ analytics_stats.days }} derniers jours.
                {# Assurez-vous que l'ID de la propriété GA4 est configuré dans votre .env.local ! #}
            </div>

            <div id="stats-container">
                
                {# Carte 1: Utilisateurs Actifs #}
                <div class="stat-card">
                    <div class="stat-value">{{ analytics_stats.activeUsers|number_format(0, ',', ' ') }}</div>
                    <div class="stat-label">Utilisateurs Actifs</div>
                </div>

                {# Carte 2: Nouveaux Utilisateurs #}
                <div class="stat-card">
                    <div class="stat-value">{{ analytics_stats.newUsers|number_format(0, ',', ' ') }}</div>
                    <div class="stat-label">Nouveaux Utilisateurs</div>
                </div>

                {# Carte 3: Taux d'engagement #}
                <div class="stat-card">
                    <div class="stat-value">{{ analytics_stats.engagementRate|number_format(2, ',', ' ') }}%</div>
                    <div class="stat-label">Taux d'engagement</div>
                </div>

            </div>
        {% else %}
            <div class="update-options" style="text-align: center;">
                <p>Statistiques non disponibles. Veuillez vérifier la connexion à l'API Google Analytics 4 (GA4).</p>
                <p style="font-size: 0.9rem;">(Erreur de configuration, de cache, ou d'accès à l'API).</p>
            </div>
        {% endif %}
    </section>
</div>
{% endblock %}

 {% block javascripts %}
            <script>
            // JavaScript pour gérer la navigation entre les sections
            document.addEventListener('DOMContentLoaded', function() {
                const navButtons = document.querySelectorAll('.nav-button');
                const mainContainer = document.getElementById('main-container');

                // Les sections sont maintenant des enfants de main-container
                const sections = {
                    0: document.getElementById('main-content'),
                    1: document.getElementById('update-section'),
                    2: document.getElementById('stats-section')
                };

                // Assurez-vous que le conteneur principal a la bonne marge au chargement
                const navBar = document.getElementById('nav-bar');
                const navWidth = navBar.offsetWidth; // width: var(--navbar-width)

                // Ajuster la marge du contenu principal en fonction de la barre de navigation
                // Note: La logique CSS gère déjà la marge basée sur nav-toggle, 
                // mais c'est bien de le garder pour le ciblage.

                navButtons.forEach((button, index) => {
                    button.addEventListener('click', () => {
                        // Cacher toutes les sections
                        Object.values(sections).forEach(section => section.style.display = 'none');
                        // Afficher la section correspondante
                        if (sections[index]) {
                            sections[index].style.display = 'block';
                        }
                    });
                });

                // Afficher la section principale par défaut
                if (sections[0]) sections[0].style.display = 'block';
                if (sections[1]) sections[1].style.display = 'none';
                if (sections[2]) sections[2].style.display = 'none';
            });

            </script>
        {% endblock %}
